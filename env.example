# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# The following `prisma+postgres` URL is similar to the URL produced by running a local Prisma Postgres
# server with the `prisma dev` CLI command, when not choosing any non-default ports or settings. The API key, unlike the
# one found in a remote Prisma Postgres URL, does not contain any sensitive information.

DATABASE_URL="file:./prisma/dev.db"

# Optional multi-tenant DB template (replace {tenant} with subdomain slug)
# Example sqlite local: file:./tenants/{tenant}.db
# Example postgres: postgresql://user:pass@host:5432/masjidku_{tenant}
TENANT_DATABASE_TEMPLATE=""

# Fallback tenant key if host/subdomain can't be resolved
DEFAULT_TENANT_KEY="default"

# Optional alias map (format: subdomain:tenantKey,subdomain2:tenantKey2)
TENANT_SLUG_ALIASES=""

# Set true to force single-tenant mode (ignore subdomain, always use DEFAULT_TENANT_KEY)
DISABLE_MULTI_TENANT="false"
NEXT_PUBLIC_DISABLE_MULTI_TENANT="false"

# Optional fallback when DATABASE_URL is not sqlite/file (e.g. prisma+postgres default)
# Will be used automatically by tenantPrisma helper if TENANT_DATABASE_TEMPLATE is empty
SQLITE_TENANT_TEMPLATE="file:./tenants/{tenant}.db"

# Upload storage (opsional)
# Jika kosong, sistem akan fallback ke <project>/storage/uploads
APP_ROOT_PATH=""
UPLOAD_STORAGE_DIR=""

# Optional smoke test multi-tenant
SMOKE_BASE_URL="http://localhost:3010"
SMOKE_TENANT_A_HOST=""
SMOKE_TENANT_A_USERNAME=""
SMOKE_TENANT_A_PASSWORD=""
SMOKE_TENANT_B_HOST=""
SMOKE_TENANT_B_USERNAME=""
SMOKE_TENANT_B_PASSWORD=""

# Optional seed user tenant otomatis
# Bisa pakai host smoke di atas, atau paksa daftar tenant via CSV
MULTITENANT_SEED_KEYS=""
MULTITENANT_SEED_PASSWORD="admin123"
MULTITENANT_SEED_USER_A=""
MULTITENANT_SEED_PASS_A=""
MULTITENANT_SEED_USER_B=""
MULTITENANT_SEED_PASS_B=""

APP_SECRET="your-app-secret"

# Gunakan relatif supaya bisa login baik dari localhost maupun akses LAN (IP laptop)
URL_API="/api"
NEXT_PUBLIC_URL_API="/api"

# Base URL API jadwal shalat eksternal (EQuran)
NEXT_PUBLIC_SHALAT_API_BASE="https://equran.id/api/v2/shalat"
SHALAT_API_BASE="https://equran.id/api/v2/shalat"

# Optional (musyawarah AI summary)
OPENAI_API_KEY=""
OPENAI_SUMMARY_MODEL="gpt-4.1"

