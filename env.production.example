# =========================
# Production Environment (Single-Tenant)
# Copy this file to .env.production on your server.
# =========================

# Prisma database URL (SQLite example)
# If using SQLite on VPS: ensure folder is writable by Node process
DATABASE_URL="file:./prisma/prod.db"

# App security
# Generate a long random secret (min 32 chars)
APP_SECRET="replace-with-long-random-secret"

# API base (relative path for same domain)
URL_API="/api"
NEXT_PUBLIC_URL_API="/api"

# External prayer schedule API
NEXT_PUBLIC_SHALAT_API_BASE="https://equran.id/api/v2/shalat"
SHALAT_API_BASE="https://equran.id/api/v2/shalat"

# Optional AI summary
OPENAI_API_KEY=""
OPENAI_SUMMARY_MODEL="gpt-4.1"

# =========================
# Force single-tenant mode
# =========================
DISABLE_MULTI_TENANT="true"
NEXT_PUBLIC_DISABLE_MULTI_TENANT="true"
DEFAULT_TENANT_KEY="default"

# Keep empty in single-tenant mode
TENANT_DATABASE_TEMPLATE=""
TENANT_SLUG_ALIASES=""

# Optional fallback template (not used when single-tenant + DATABASE_URL is set)
SQLITE_TENANT_TEMPLATE="file:./tenants/{tenant}.db"

# Optional scripts (safe to keep empty in production)
SMOKE_BASE_URL=""
SMOKE_TENANT_A_HOST=""
SMOKE_TENANT_A_USERNAME=""
SMOKE_TENANT_A_PASSWORD=""
SMOKE_TENANT_B_HOST=""
SMOKE_TENANT_B_USERNAME=""
SMOKE_TENANT_B_PASSWORD=""
MULTITENANT_SEED_KEYS=""
MULTITENANT_SEED_PASSWORD="admin123"
MULTITENANT_SEED_USER_A=""
MULTITENANT_SEED_PASS_A=""
MULTITENANT_SEED_USER_B=""
MULTITENANT_SEED_PASS_B=""
